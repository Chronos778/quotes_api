PORT=3000
API_PASSWORD=your_secure_password
# Comma-separated browser origins; leave empty for local/open usage
CORS_ORIGINS=https://your-frontend.vercel.app,https://www.yourdomain.com
# Proxy hop trust for accurate client IP/rate limiting (Vercel usually 1)
TRUST_PROXY=1
# Optional payload limits
MAX_QUOTE_TEXT_LENGTH=500
MAX_AUTHOR_LENGTH=100
# Turso Database Credentials (Required for Cloud/Vercel)
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token
# Push Notifications (VAPID keys — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@example.com
# Optional: Cron job auth secret (generate with: openssl rand -hex 32)
CRON_SECRET=
